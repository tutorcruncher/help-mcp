# ─── Auth (GitHub OAuth + org gating) ─────────────────────────────────────────
# GitHub OAuth App credentials (Settings → Developer settings → OAuth Apps).
# The OAuth App's Authorization callback URL must be <BASE_URL>/auth/callback
GITHUB_OAUTH_CLIENT_ID=Ov23li_xxxxxxxxxxxx
GITHUB_OAUTH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public HTTPS base URL of THIS server (OAuth callback root).
BASE_URL=https://your-app.herokuapp.com

# GitHub scopes required to verify org membership (space-separated).
GITHUB_SCOPES=read:org read:user

# Restrict access to active members of this GitHub org. Strongly recommended.
ALLOWED_GITHUB_ORG=tutorcruncher

# The server refuses to start without ALLOWED_GITHUB_ORG unless this is 1.
# Set to 1 ONLY to deliberately allow any authenticated GitHub user (e.g. local dev).
ALLOW_UNGATED=0

# Space-separated OAuth client redirect URIs permitted during registration.
ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback

# Signing key for the FastMCP-issued JWTs (generate a strong random value in prod).
JWT_SIGNING_KEY=change-me-in-production

# ─── Help docs (Intercom Articles API — one token per workspace) ──────────────
# Same API host for every workspace; only the tokens differ.
INTERCOM_API_BASE=https://api.intercom.io

# Intercom access token for the TutorCruncher help-centre workspace.
INTERCOM_TOKEN_TUTORCRUNCHER=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Intercom access token for the Bobbin help-centre workspace (separate workspace).
INTERCOM_TOKEN_BOBBIN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── API docs (tc-api-docs GitHub repo) ───────────────────────────────────────
TC_API_DOCS_REPO=tutorcruncher/tc-api-docs
TC_API_DOCS_REF=master

# Optional GitHub token to raise raw-content fetch rate limits (distinct from the
# OAuth App credentials above; a classic/fine-grained PAT with public read is fine).
GITHUB_TOKEN=

# ─── General ──────────────────────────────────────────────────────────────────
# In-memory cache TTL (seconds) for latency/rate-limit protection. NOT a source of
# truth — content is re-fetched live on expiry.
CACHE_TTL_SECONDS=300

# Max results returned by search_help.
SEARCH_RESULT_LIMIT=8

# Port the MCP server binds to. Heroku sets this automatically.
PORT=8000
